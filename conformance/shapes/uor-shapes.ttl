uor-sh:BettiNumberShape
    a               sh:NodeShape ;
    sh:targetClass  observable:BettiNumber ;
    rdfs:label      "BettiNumberShape" .

uor-sh:SpectralGapShape
    a               sh:NodeShape ;
    sh:targetClass  observable:SpectralGap ;
    rdfs:label      "SpectralGapShape" .

